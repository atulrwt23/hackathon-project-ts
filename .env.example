# Account identity — set once per deployment, never sent in requests
GET_IT_ACCOUNT_ID=cricbuzz

# Where project config.json and context.md files live (default: ./projects)
GET_IT_PROJECTS_DIR=./projects

# Metadata DB — stores embeddings and project registry (needs pgvector extension)
NL2SQL_METADATA_DSN=postgresql://nl2sql:nl2sql@localhost:55433/nl2sql

# Per-project DSN overrides (env var wins over config.json)
# Pattern: GET_IT_PROJECT_{PROJECT_ID_UPPERCASE}_DSN
GET_IT_PROJECT_IPL_DSN=postgresql://ipl:ipl@localhost:55434/ipl

# AI providers
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...
