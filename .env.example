# Required — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Required — get from https://www.voyageai.com/
VOYAGE_API_KEY=pa-...

# Required — postgres with pgvector for BusinessDNA's internal vector store
# This is NOT your app's database. Spin one up with:
#   docker run -d --name businessdna-meta \
#     -e POSTGRES_USER=biz -e POSTGRES_PASSWORD=biz -e POSTGRES_DB=biz \
#     -p 55433:5432 pgvector/pgvector:pg16
BUSINESSDNA_METADATA_DSN=postgresql://biz:biz@localhost:55433/biz

# Optional overrides
# BUSINESSDNA_PORT=7331
# NL2SQL_LLM_MODEL=claude-sonnet-4-6
# NL2SQL_EMBED_MODEL=voyage-3
# NL2SQL_MAX_ROWS=1000
