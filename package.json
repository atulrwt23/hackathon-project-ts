{
  "name": "businessdna",
  "version": "1.0.0",
  "description": "Teach AI how your business works — scan your codebase + DB and ask plain-English questions",
  "type": "module",
  "main": "dist/app.js",
  "bin": {
    "businessdna": "./bin/businessdna.js"
  },
  "files": [
    "bin/",
    "dist/",
    "frontend/dist/"
  ],
  "scripts": {
    "build:backend": "tsc -p tsconfig.json",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:backend && npm run build:frontend",
    "plugin": "node bin/businessdna.js",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@fastify/static": "^9.1.3",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "fastify": "^5.0.0",
    "node-sql-parser": "^5.3.0",
    "open": "^11.0.0",
    "p-limit": "^7.3.0",
    "pg": "^8.13.0",
    "pgvector": "^0.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
